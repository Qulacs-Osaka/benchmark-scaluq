{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",
			"label": "CUDA: nvcc build active file",
			"command": "/usr/local/cuda/bin/nvcc",
			"args": [
				"-I",
				"${CUQUANTUM_ROOT}/include",
				"-L",
				"${CUQUANTUM_ROOT}/lib",
				"-l",
				"custatevec",
				"-g",
				"${file}",
				"-o",
				"${fileDirname}/${fileBasenameNoExtension}"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"group": "build",
			"detail": "compiler: /usr/local/cuda/bin/nvcc"
		}
	]
}