{
    "name": "cuda-12-devcontainer",
    "build": {
        "dockerfile": "../Dockerfile.batch",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "python.defaultInterpreterPath": "/usr/bin/python3"
            },
            "extensions": [
                "ms-python.python",
                "ms-azuretools.vscode-docker",
                "ms-vscode.cpptools"
            ]
        }
    },
    "runArgs": [
        "--gpus",
        "all"
    ],
    "remoteUser": "root",
    "postCreateCommand": "wget -qO- https://starship.rs/install.sh | sh -s -- -y && echo 'eval \"$(starship init bash)\"' >> ~/.bashrc"
}