{
    "name": "cuda-12-devcontainer",
    "build": {
        "dockerfile": "../Dockerfile.batch",
        "context": ".."
    },
    "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.defaultInterpreterPath": "/usr/bin/python3"
    },
    "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "ms-vscode.cpptools"
    ],
    "runArgs": [
        "--gpus",
        "all"
    ],
    "waitFor": "containerStarted",
    "remoteUser": "root"
}